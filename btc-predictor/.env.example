# Data paths
BINANCE_TICK_DIR=~/binance_ticks/BTCUSDT
DATA_PROCESSED_DIR=./data/processed
DATA_LIVE_DB=./data/live/ticks.sqlite

# Model
MODEL_PATH=./src/model/model.pkl
FEATURE_NAMES_PATH=./src/model/feature_names.json
TRAINING_METADATA_PATH=./src/model/training_metadata.json

# Coinbase WebSocket (Advanced Trade)
COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
PRODUCT_ID=BTC-USD

# Prediction server
API_HOST=0.0.0.0
API_PORT=8000

# Training config
RECENCY_HALF_LIFE_DAYS=90
MIN_TRAINING_ROWS=50000
TRAIN_SAMPLE_POINTS=15

# Logging
LOG_LEVEL=INFO
