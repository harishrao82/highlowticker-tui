// Combined: 15-Minute Opening Level + NQSTATS
// 15m open line with delta label + ALN session boxes/stats from nqstats.com
//
// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
//@ unchained-fx

//@version=5
indicator("15m Open + NQSTATS", shorttitle="15mO+NQ", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

///////////////////////////////////////////////////////////////////////////////
//  15-MINUTE OPEN LEVEL + DELTA LABEL
///////////////////////////////////////////////////////////////////////////////

show15m     = input.bool(true, "Enable 15m Open Level", group = "15m Open Level")
line_width  = input.int(2, "Line Width", minval = 1, maxval = 10, group = "15m Open Level")
rightOffset = input.int(30, "Right Offset", minval = 0, maxval = 50, group = "15m Open Level")
line_col    = input.color(color.orange, "Line Color", group = "15m Open Level")
label_col   = input.color(color.white, "Label Text Color", group = "15m Open Level")
show_label  = input.bool(true, "Show Label", group = "15m Open Level")
ref_offset  = input.int(-2, "Ref Offset (min from 15m start)", minval = -7, maxval = 7, group = "15m Open Level")

res = "15"

o15 = request.security(syminfo.tickerid, res, open[0], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_on)

bars_passed = ta.barssince(ta.change(time(res)) != 0)
dt = ta.change(time)

x1 = time + math.round(dt * (-bars_passed))
xn = time + math.round(dt * rightOffset)

// 1-min closes at fixed lookbacks — works on any chart timeframe
sec0 = request.security(syminfo.tickerid, "1", close,    gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
sec1 = request.security(syminfo.tickerid, "1", close[1], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
sec2 = request.security(syminfo.tickerid, "1", close[2], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
sec3 = request.security(syminfo.tickerid, "1", close[3], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
sec4 = request.security(syminfo.tickerid, "1", close[4], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
sec5 = request.security(syminfo.tickerid, "1", close[5], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)
sec6 = request.security(syminfo.tickerid, "1", close[6], gaps = barmerge.gaps_off, lookahead = barmerge.lookahead_off)

var float ref_close = na
var int   win_start = na

new_window = ta.change(time(res)) != 0

if show15m and new_window
    win_start := time
    if ref_offset == 0
        ref_close := o15
    else if ref_offset == -1
        ref_close := sec0
    else if ref_offset == -2
        ref_close := sec1
    else if ref_offset == -3
        ref_close := sec2
    else if ref_offset == -4
        ref_close := sec3
    else if ref_offset == -5
        ref_close := sec4
    else if ref_offset == -6
        ref_close := sec5
    else if ref_offset == -7
        ref_close := sec6
    else
        ref_close := na

// Positive offsets: capture once enough time has elapsed after window start
if show15m and ref_offset > 0 and na(ref_close) and not na(win_start) and time > win_start + ref_offset * 60000
    ref_close := sec0

var line  ln15 = na
var label lb15 = na

if show15m and o15[1] != o15
    ln15 := line.new(x1 = x1, y1 = o15, x2 = xn, y2 = o15, xloc = xloc.bar_time, color = line_col, style = line.style_solid, width = line_width)
    line.delete(ln15[1])
    if show_label
        lb15 := label.new(x = xn, y = o15, xloc = xloc.bar_time, text = "", color = line_col, textcolor = label_col, style = label.style_label_left)
        label.delete(lb15[1])

if show15m and not na(ln15) and line.get_x2(ln15) != bar_index
    line.set_x2(ln15, xn)

if show15m and show_label and not na(lb15)
    label.set_x(lb15, xn)
    delta_pct = na(ref_close) ? 0.0 : (close - ref_close) / ref_close * 100
    offset_str = ref_offset >= 0 ? "t+" + str.tostring(ref_offset) : "t" + str.tostring(ref_offset)
    label.set_text(lb15, na(ref_close) ? offset_str + " waiting..." : offset_str + " " + str.tostring(ref_close, "#.##") + " Δ" + str.tostring(delta_pct, "#.###") + "%")


///////////////////////////////////////////////////////////////////////////////
//  NQSTATS — ALN Session Boxes + Stats Table + Previous Day High/Low
///////////////////////////////////////////////////////////////////////////////

// Session box inputs
showSessionBoxes = input.bool(true, "Show Session boxes", group = "Session Boxes")
asia_color       = input.color(color.red, "Asia Color", group = "Session Boxes", inline = "2")
london_color     = input.color(color.blue, "London Color", group = "Session Boxes", inline = "2")
newyork_color    = input.color(color.green, "NY Color", group = "Session Boxes", inline = "2")
borderwidth      = input.int(2, "Box Border Width", options=[1,2,3], group = "Session Boxes")

// Previous Day High/Low inputs
showPrevDayHL      = input.bool(true, "Show Previous Day High/Low", group = "Previous Day Levels")
prevDayHighColor   = input.color(color.orange, "Previous Day High Color", group = "Previous Day Levels")
prevDayLowColor    = input.color(color.purple, "Previous Day Low Color", group = "Previous Day Levels")
prevDayLineWidth   = input.int(1, "Line Width", minval=1, maxval=4, group = "Previous Day Levels")
showPrevDayLabels  = input.bool(true, "Show Labels", group = "Previous Day Levels")

// Stats table inputs
tablePosition      = input.string("Top Right", "Table Position", options=["Top Left", "Top Right", "Middle Left", "Middle Right", "Bottom Left", "Bottom Right"], group = "Stats Table")
tableTopBgColor    = input.color(color.gray, "Table Top Row Background Color", group = "Stats Table")
tableTopTextColor  = input.color(color.white, "Table Top Row Text Color", group = "Stats Table")
tableBodyBgColor   = input.color(color.white, "Table Body Background Color", group = "Stats Table")
tableBodyTextColor = input.color(color.black, "Table Body Text Color", group = "Stats Table")
tableTextSize      = input.string("Small", "Table Text Size", options=["Tiny", "Small", "Normal", "Large", "Huge"], group = "Stats Table")

// Troubleshooting
showSessionHighLow = input.bool(false, "Show Session Table of Highs/Lows", group = "Troubleshooting")
ttablePosition     = input.string("Middle Right", "Table Position", options=["Top Left", "Top Right", "Middle Left", "Middle Right", "Bottom Left", "Bottom Right"], group = "Troubleshooting")

// Session times for Session Boxes
asia_sess    = "2000-0200"
london_sess  = "0200-0800"
newyork_sess = "0800-1600"
na_color     = color.new(color.gray, 100)

// Convert position string to PineScript position enum
getPosition(pos) =>
    switch pos
        "Top Left"     => position.top_left
        "Top Right"    => position.top_right
        "Middle Left"  => position.middle_left
        "Middle Right" => position.middle_right
        "Bottom Left"  => position.bottom_left
        "Bottom Right" => position.bottom_right

// Convert text size string to PineScript size enum
getTextSize(sz) =>
    switch sz
        "Tiny"   => size.tiny
        "Small"  => size.small
        "Normal" => size.normal
        "Large"  => size.large
        "Huge"   => size.huge

is_newbar(string sess) =>
    t = time('D', sess, timezone = "America/New_York")
    na(t[1]) and not na(t) or t[1] < t

is_session(string sess) =>
    not na(time('D', sess, timezone = "America/New_York"))

range_box(string session = "2000-0000", color col = color.red, string bodies_wicks = "Wicks") =>
    _high = bodies_wicks == "Wicks" ? high : math.max(open, close)
    _low  = bodies_wicks == "Wicks" ? low  : math.min(open, close)

    var box s_box = na
    if is_newbar(session)
        s_box := box.new(bar_index, _high, bar_index, _low, border_color = col, bgcolor = na_color, border_width = borderwidth)
    else if is_session(session)
        if _high > box.get_top(s_box)
            box.set_top(s_box, _high)
        if _low < box.get_bottom(s_box)
            box.set_bottom(s_box, _low)
        box.set_right(s_box, bar_index)

    s_box

/////////////////////////
// Previous Day High/Low
/////////////////////////

var float prevDayHigh = na
var float prevDayLow = na
var float currentDayHigh = na
var float currentDayLow = na
var int prevDayStartBar = na
var int currentDayStartBar = na
var line prevHighLine = na
var line prevLowLine = na
var label prevHighLabel = na
var label prevLowLabel = na

tradingDayStart = time(timeframe.period, "1800-1801", "America/New_York")
inTradingDay    = time(timeframe.period, "1800-1759", "America/New_York")

newTradingDay = not na(tradingDayStart) and na(tradingDayStart[1])

if newTradingDay
    prevDayHigh      := currentDayHigh
    prevDayLow       := currentDayLow
    prevDayStartBar  := currentDayStartBar
    currentDayHigh   := high
    currentDayLow    := low
    currentDayStartBar := bar_index

if not na(inTradingDay)
    currentDayHigh := math.max(high, nz(currentDayHigh, high))
    currentDayLow  := math.min(low, nz(currentDayLow, low))
    if na(currentDayStartBar)
        currentDayStartBar := bar_index

if showPrevDayHL and not na(prevDayHigh) and not na(prevDayLow)
    if not na(prevHighLine)
        line.delete(prevHighLine)
    if not na(prevLowLine)
        line.delete(prevLowLine)
    if not na(prevHighLabel)
        label.delete(prevHighLabel)
    if not na(prevLowLabel)
        label.delete(prevLowLabel)

    endBar = bar_index + 1

    prevHighLine := line.new(currentDayStartBar, prevDayHigh, endBar, prevDayHigh,
         color=prevDayHighColor, width=prevDayLineWidth, style=line.style_dashed, extend=extend.none)
    prevLowLine := line.new(currentDayStartBar, prevDayLow, endBar, prevDayLow,
         color=prevDayLowColor, width=prevDayLineWidth, style=line.style_dashed, extend=extend.none)

    if showPrevDayLabels
        prevHighLabel := label.new(endBar, prevDayHigh, "PDH " + str.tostring(prevDayHigh, "#.##"),
             style=label.style_label_left, color=color.new(prevDayHighColor, 80), textcolor=prevDayHighColor, size=size.small)
        prevLowLabel := label.new(endBar, prevDayLow, "PDL " + str.tostring(prevDayLow, "#.##"),
             style=label.style_label_left, color=color.new(prevDayLowColor, 80), textcolor=prevDayLowColor, size=size.small)

/////////////////////////
// Session Stats
/////////////////////////

inAsia   = time(timeframe.period, "2000-0200", "America/New_York")
inLondon = time(timeframe.period, "0200-0800", "America/New_York")
inNY     = time(timeframe.period, "0800-1400", "America/New_York")

var float asiaHigh = na
var float asiaLow = na
var float londonHigh = na
var float londonLow = na
var float nyHigh = na
var float nyLow = na
var float asiaHighFinal = na
var float asiaLowFinal = na
var float londonHighFinal = na
var float londonLowFinal = na
var float nyHighFinal = na
var float nyLowFinal = na
var table currentTable = na
var table ttable = na

newDay    = dayofmonth != dayofmonth[1]
resetAsia = hour(time) == 18 and minute(time) == 0

if newDay
    londonHigh      := na
    londonLow       := na
    nyHigh          := na
    nyLow           := na
    asiaHighFinal   := na
    asiaLowFinal    := na
    londonHighFinal := na
    londonLowFinal  := na
    nyHighFinal     := na
    nyLowFinal      := na
    if not na(currentTable)
        table.delete(currentTable)
        currentTable := na

if resetAsia
    asiaHigh := na
    asiaLow  := na

if inAsia
    asiaHigh := math.max(high, nz(asiaHigh, low))
    asiaLow  := math.min(low, nz(asiaLow, high))
    if hour(time) == 1 and minute(time) == 59 and not na(inAsia)
        asiaHighFinal := asiaHigh
        asiaLowFinal  := asiaLow

if inLondon
    londonHigh := math.max(high, nz(londonHigh, low))
    londonLow  := math.min(low, nz(londonLow, high))
    if hour(time) == 7 and minute(time) == 59 and not na(inLondon)
        londonHighFinal := londonHigh
        londonLowFinal  := londonLow

if inNY
    nyHigh := math.max(high, nz(nyHigh, low))
    nyLow  := math.min(low, nz(nyLow, high))
    if hour(time) == 13 and minute(time) == 59 and not na(inNY)
        nyHighFinal := nyHigh
        nyLowFinal  := nyLow

    if not na(asiaHigh) and not na(londonHigh)
        if not na(currentTable)
            table.delete(currentTable)
            currentTable := na

        // Pattern 1: London engulfs Asia
        if londonHigh > asiaHigh and londonLow < asiaLow
            currentTable := table.new(getPosition(tablePosition), 3, 6, bgcolor=tableBodyBgColor, frame_width = 1, frame_color = color.black, border_width = 1, border_color = color.black)
            table.cell(currentTable, 0, 0, "London Engulfs Asia\n(Pattern 1)", text_size=getTextSize(tableTextSize), bgcolor=tableTopBgColor, text_color=tableTopTextColor)
            table.merge_cells(currentTable, 0, 0, 1, 0)
            table.cell(currentTable, 0, 1, "NY Takes London\nHigh or Low", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 1, "98%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 2, "NY Engulfs London", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 2, "43%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)

        // Pattern 2: London stays within Asia
        else if londonHigh <= asiaHigh and londonLow >= asiaLow
            currentTable := table.new(getPosition(tablePosition), 3, 8, bgcolor=tableBodyBgColor, frame_width = 1, frame_color = color.black, border_width = 1, border_color = color.black)
            table.cell(currentTable, 0, 0, "London Within Asia\n(Pattern 2)", text_size=getTextSize(tableTextSize), bgcolor=tableTopBgColor, text_color=tableTopTextColor)
            table.merge_cells(currentTable, 0, 0, 1, 0)
            table.cell(currentTable, 0, 1, "Occurrences (10y)", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 1, "168", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 2, "NY Takes London High/Low", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 2, "95%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 3, "NY Takes Asia High/Low", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 3, "91%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 4, "NY Engulfs Overnight", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 4, "39%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)

        // Pattern 3: London high above Asia high, low not below Asia low
        else if londonHigh > asiaHigh and londonLow >= asiaLow
            currentTable := table.new(getPosition(tablePosition), 3, 9, bgcolor=tableBodyBgColor, frame_width = 1, frame_color = color.black, border_width = 1, border_color = color.black)
            table.cell(currentTable, 0, 0, "London Above Asia High\n(Pattern 3)", text_size=getTextSize(tableTextSize), bgcolor=tableTopBgColor, text_color=tableTopTextColor)
            table.merge_cells(currentTable, 0, 0, 1, 0)
            table.cell(currentTable, 0, 2, "NY Takes London High", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 2, "79%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 3, "NY Takes London Low", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 3, "63%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 4, "NY Takes Asia Low", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 4, "51%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 5, "NY Engulfs Overnight", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 5, "35%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)

        // Pattern 4: London low below Asia low, high not above Asia high
        else if londonLow < asiaLow and londonHigh <= asiaHigh
            currentTable := table.new(getPosition(tablePosition), 3, 9, bgcolor=tableBodyBgColor, frame_width = 1, frame_color = color.black, border_width = 1, border_color = color.black)
            table.cell(currentTable, 0, 0, "London Below Asia Low\n(Pattern 4)", text_size=getTextSize(tableTextSize), bgcolor=tableTopBgColor, text_color=tableTopTextColor)
            table.merge_cells(currentTable, 0, 0, 1, 0)
            table.cell(currentTable, 0, 2, "NY Takes London Low", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 2, "73%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 3, "NY Takes London High", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 3, "66%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 4, "NY Takes Asia High", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 4, "54%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 0, 5, "NY Engulfs Overnight", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(currentTable, 1, 5, "33%", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)

        if showSessionHighLow
            ttable := table.new(getPosition(ttablePosition), 3, 3, bgcolor=tableBodyBgColor, frame_width = 1, frame_color = color.black, border_width = 1, border_color = color.black)
            table.cell(ttable, 0, 0, "Session Highs/Lows", text_size=getTextSize(tableTextSize), bgcolor=tableTopBgColor, text_color=tableTopTextColor)
            table.merge_cells(ttable, 0, 0, 1, 0)
            table.cell(ttable, 0, 1, "Asia H/L", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(ttable, 1, 1, str.tostring(asiaHigh, "#.##") + "/" + str.tostring(asiaLow, "#.##"), text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(ttable, 0, 2, "London H/L", text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)
            table.cell(ttable, 1, 2, str.tostring(londonHigh, "#.##") + "/" + str.tostring(londonLow, "#.##"), text_size=getTextSize(tableTextSize), bgcolor=tableBodyBgColor, text_color=tableBodyTextColor)

if showSessionBoxes
    range_box(asia_sess, asia_color, "Wicks")
    range_box(london_sess, london_color, "Wicks")
    range_box(newyork_sess, newyork_color, "Wicks")
